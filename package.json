{
  "name": "etheral-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "start": "turbo start --parallel",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:e2e:jsonplaceholder": "playwright test tests/e2e/jsonplaceholder-ui-metrics-flow.spec.ts",
    "test:headless-mcp-tool": "bun scripts/validation/run-headless-mcp-tool-validation.ts",
    "research:benchmark": "bun scripts/research/run-paper-mvp-benchmark.ts",
    "research:toolcall-matrix": "bun scripts/research/run-backend-toolcall-matrix.ts",
    "research:export": "bun scripts/research/export-research-report.ts",
    "manager": "turbo manager --filter=@etheral-system/mcp-gen",
    "proxy": "turbo proxy --filter=@etheral-system/mcp-gen",
    "dev:backend": "turbo dev:backend --filter=@etheral-system/chatbot-mcp-client",
    "docker:config": "docker compose config",
    "docker:up": "docker compose up --build"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "mongodb": "^7.0.0",
    "turbo": "^2.9.14"
  }
}
