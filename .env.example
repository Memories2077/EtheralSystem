# Google Gemini API
# Models: gemini-2.5-flash, gemini-2.5-pro
GEMINI_API_KEY="your_gemini_api_key"
GEMINI_MODEL="gemini-2.5-flash"

# Groq API
# Models: llama-3.3-70b-versatile, qwen/qwen3-32b
GROQ_API_KEY="your_groq_api_key"
GROQ_MODEL="llama-3.3-70b-versatile"

# MetaClaw Proxy Integration (Anthropic Claude via proxy)
# When METACLAW_ENABLED=true, set METACLAW_API_KEY explicitly for shared/non-local environments.
# The application still supports the local development dummy value "metaclaw" when no key is provided.
METACLAW_ENABLED=false
METACLAW_BASE_URL="http://localhost:30000/v1"
METACLAW_API_KEY="your_metaclaw_api_key"
METACLAW_MODEL="qwen/qwen3-next-80b-a3b-instruct"

# General LLM Settings (used by all providers)
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_MS=300000
# Deprecated compatibility fallbacks for one transition period only.
# OPENAI_TEMPERATURE=0.2
# OPENAI_TIMEOUT_MS=300000

# Debug Options (Optional)
# Set to "true" to enable detailed debug logging for GenAI responses
DEBUG_GENAI=false

# Manager and generated MCP server URLs
# PUBLIC_URL is the externally reachable proxy URL used in generated MCP public URLs.
PUBLIC_URL=http://localhost:8081
# MANAGER_URL is used by generated Docker containers for ready callbacks.
MANAGER_URL=http://docker-manager:8080

# Default Docker Image for MCP Servers
DEFAULT_MCP_IMAGE=mcp-gen

# Network Configuration
# Set the Docker network name for newly created containers (external: true)
MCP_NETWORK=mcp-network

# CORS Configuration
# Comma-separated list of allowed origins for browser requests.
# Local frontend default: http://localhost:9002
CORS_ORIGINS=http://localhost:9002

# Infrastructure URLs for Docker Compose
MONGO_URI=mongodb://mongodb:27017
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Feedback Rate Limiting
# Time window in milliseconds (default: 15 minutes)
FEEDBACK_RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window per IP (default: 100)
FEEDBACK_RATE_LIMIT_MAX=100

# Dynamic Skill Selection (Optional)
DYNAMIC_SKILL_SELECTION=false
SKILL_SELECTION_VARIANT=dynamic
SKILL_SELECTION_CONTROL_TRAFFIC=0.1
SKILL_SELECTION_DYNAMIC_TRAFFIC=0.45
SKILL_SELECTION_HYBRID_TRAFFIC=0.45
SKILL_SELECTION_HYBRID_CONFIDENCE_THRESHOLD=0.7
