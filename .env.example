# ===========================================================================
# LLM Provider Keys (at least one required)
# ===========================================================================
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===========================================================================
# MetaClaw (optional external integration)
# ===========================================================================
METACLAW_API_KEY=
METACLAW_BASE_URL=

# ===========================================================================
# Service URLs
# ===========================================================================
MONGODB_URL=mongodb://mongodb:27017
MONGO_URI=mongodb://mongodb:27017
LANGGRAPH_API_URL=http://agent-service:2024
MCP_GEN_URL=http://docker-manager:8080
MCP_BASE_URL=http://docker-manager:8080/api
MCP_MANAGER_URL=http://docker-manager:8080

# ===========================================================================
# MCP Generator
# ===========================================================================
PORT=8080
PUBLIC_URL=http://localhost:8081
MANAGER_URL=http://docker-manager:8080
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
CORS_ORIGINS=http://localhost:9002
BACKEND_HOST=host.docker.internal
USE_DOCKER_PING=false

# ===========================================================================
# Chatbot
# ===========================================================================
BACKEND_PORT=8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ===========================================================================
# Infrastructure Defaults
# ===========================================================================
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
