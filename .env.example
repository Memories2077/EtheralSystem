# Google Gemini API
# Models: gemini-2.5-flash, gemini-2.5-pro
GEMINI_API_KEY="your_gemini_api_key"
GEMINI_MODEL="gemini-2.5-flash"

# Groq API
# Models: llama-3.3-70b-versatile, qwen/qwen3-32b
GROQ_API_KEY="your_groq_api_key"
GROQ_MODEL="llama-3.3-70b-versatile"

# MetaClaw Proxy Integration (Anthropic Claude via proxy)
# When enabled, all AI requests route through MetaClaw
METACLAW_ENABLED=false
METACLAW_BASE_URL="http://localhost:30000/v1"
METACLAW_API_KEY="your_metaclaw_api_key"

# General LLM Settings (used by all providers)
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_MS=300000

# Debug Options (Optional)
# Set to "true" to enable detailed debug logging for GenAI responses
DEBUG_GENAI=false

# Default Docker Image for MCP Servers
DEFAULT_MCP_IMAGE=mcp-gen

# Network Configuration
# Set the Docker network name for newly created containers (external: true)
MCP_NETWORK=mcp-network
