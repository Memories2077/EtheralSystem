# OpenAI API Configuration
OPENAI_BASE_URL=https://llmapi.iec-uit.com/v1
OPENAI_API_KEY=<API_KEY>
OPENAI_MODEL=iec-model
OPENAI_TEMPERATURE=0.5
OPENAI_TIMEOUT_MS=60000

# Debug Options (Optional)
# Set to "true" to enable detailed debug logging for GenAI responses
# This will log response structure, reasoning content length, etc.
DEBUG_GENAI=false

# Gemini API
GEMINI_API_KEY="your_api_key"

# Groq API
GROQ_API_KEY="your_api_key"

# Default Docker Image for MCP Servers
DEFAULT_MCP_IMAGE=mcp-gen